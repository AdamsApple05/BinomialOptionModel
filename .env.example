# .env.example — copy this file to .env and fill in your values.
# .env is gitignored; never commit your real .env file.

# Polygon.io REST API key (required for run_download.py and run_research.py).
# Sign up at https://polygon.io
#
# Free tier: limited to recent ~2 years of data, 5 calls/minute.
#   If on the free tier, set calls_per_minute=5 in GlobalConfig (config.py).
#
# Paid Starter tier (recommended): unlimited history, 1000 calls/minute.
#   The default GlobalConfig uses calls_per_minute=1000.
POLYGON_API_KEY=your_polygon_api_key_here
